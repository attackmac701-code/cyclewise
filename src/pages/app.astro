---
import Layout from '../layouts/Layout.astro';
import { PHASES } from '../data/phases.ts';
---
<Layout title="CycleWise — Dashboard" noHeader={false}>
  <!-- Setup modal (shown when no data) -->
  <div id="setup-modal" class="modal-overlay" style="display:none;">
    <div class="modal-card">
      <div class="modal-emoji">🌙</div>
      <h2>Set up CycleWise</h2>
      <p>Enter the first day of her last period and her average cycle length. This stays on your device — we never see it.</p>
      <form id="setup-form">
        <label>
          <span>First day of last period</span>
          <input type="date" id="period-date" required />
        </label>
        <label>
          <span>Average cycle length (days)</span>
          <input type="number" id="cycle-length" value="28" min="21" max="35" required />
        </label>
        <button type="submit" class="btn btn-primary" style="width:100%;">Start Tracking</button>
      </form>
    </div>
  </div>

  <div class="app-wrap" id="app-content" style="display:none;">
    <!-- TODAY CARD -->
    <div class="today-section">
      <div class="today-inner">
        <div class="today-meta">
          <div id="today-cycle-day" class="cycle-day-badge">Day —</div>
          <button id="new-period-btn" class="new-period-btn" title="Her period started today">New Period</button>
          <button id="edit-setup" class="edit-btn" title="Edit cycle settings">⚙️</button>
        </div>
        <div id="today-phase-emoji" class="today-emoji">🌙</div>
        <h1 id="today-phase-name" class="today-phase-name">Loading...</h1>
        <p id="today-tagline" class="today-tagline">—</p>

        <div id="today-briefing" class="today-briefing">
          <!-- Populated by JS -->
        </div>

        <!-- Detail — scroll to see -->
        <div id="today-detail" class="today-detail"></div>

        <!-- Pro teaser / Pro content -->
        <div id="pro-section"></div>
      </div>
    </div>

    <!-- CALENDAR -->
    <div class="calendar-section page-wrap">
      <h2 class="section-heading">Her Cycle Calendar</h2>
      <div class="calendar-legend">
        <span class="leg menstrual">🌑 Menstrual</span>
        <span class="leg follicular">🌱 Follicular</span>
        <span class="leg ovulation">✨ Ovulation</span>
        <span class="leg luteal">🌘 Luteal</span>
      </div>
      <div class="cal-nav">
        <button id="cal-prev" class="cal-nav-btn">← Prev</button>
        <span id="cal-month-label" class="cal-month-label">—</span>
        <button id="cal-next" class="cal-nav-btn">Next →</button>
      </div>
      <div id="calendar-grid" class="calendar-grid">
        <!-- populated by JS -->
      </div>
    </div>

    <!-- PHASE GUIDE -->
    <div class="guide-section page-wrap">
      <h2 class="section-heading">Full Phase Guide</h2>
      <div id="phase-guide-tabs" class="phase-tabs">
        <button class="tab-btn active" data-phase="menstrual">Menstrual</button>
        <button class="tab-btn" data-phase="follicular">Follicular</button>
        <button class="tab-btn" data-phase="ovulation">Ovulation</button>
        <button class="tab-btn" data-phase="luteal">Luteal</button>
      </div>
      <div id="phase-guide-content" class="phase-guide-content">
        <!-- populated by JS -->
      </div>
    </div>
  </div>
</Layout>

<script>
  // Daily quotes per phase
  const QUOTES = {
    menstrual: [
      { text: 'Almost everything will work again if you unplug it for a few minutes — including you.', author: 'Anne Lamott' },
      { text: 'Rest is not idleness, and to lie sometimes on the grass under trees on a summer\'s day is by no means a waste of time.', author: 'John Lubbock' },
      { text: 'In the middle of difficulty lies opportunity — but first, rest.', author: 'Adapted from Einstein' },
      { text: 'Nourishing yourself in a way that helps you blossom in the direction you want to go is attainable.', author: 'Deborah Day' },
      { text: 'Take rest; a field that has rested gives a bountiful crop.', author: 'Ovid' },
      { text: 'The quieter you become, the more you are able to hear.', author: 'Rumi' },
      { text: 'Sometimes the most productive thing you can do is rest.', author: 'Mark Black' },
      { text: 'Within you there is a stillness and a sanctuary to which you can retreat at any time.', author: 'Hermann Hesse' },
      { text: 'Surrender to what is. Let go of what was. Have faith in what will be.', author: 'Sonia Ricotti' },
      { text: 'The soul always knows what to do to heal itself. The challenge is to silence the mind.', author: 'Caroline Myss' },
    ],
    follicular: [
      { text: 'With the new day comes new strength and new thoughts.', author: 'Eleanor Roosevelt' },
      { text: 'Every morning we are born again. What we do today matters most.', author: 'Buddha' },
      { text: 'Life is not measured by the number of breaths we take, but by the moments that take our breath away.', author: 'Maya Angelou' },
      { text: 'The secret of getting ahead is getting started.', author: 'Mark Twain' },
      { text: 'Energy and persistence conquer all things.', author: 'Benjamin Franklin' },
      { text: 'Enthusiasm is the electricity of life.', author: 'Gordon Parks' },
      { text: 'In the spring, at the end of the day, you should smell like dirt.', author: 'Margaret Atwood' },
      { text: 'Do something today that your future self will thank you for.', author: 'Sean Patrick Flanery' },
      { text: 'The beginning is always today.', author: 'Mary Shelley' },
      { text: 'Act as if what you do makes a difference. It does.', author: 'William James' },
    ],
    ovulation: [
      { text: 'You are enough just as you are. Each emotion you feel, everything in your life — it is there for a reason.', author: 'Peaceful Warrior' },
      { text: 'To love and be loved is to feel the sun from both sides.', author: 'David Viscott' },
      { text: 'We are most alive when we are in love.', author: 'John Updike' },
      { text: 'The best and most beautiful things in the world cannot be seen or even touched — they must be felt with the heart.', author: 'Helen Keller' },
      { text: 'Wherever you go, go with all your heart.', author: 'Confucius' },
      { text: 'You yourself, as much as anybody in the entire universe, deserve your love and affection.', author: 'Buddha' },
      { text: 'Be the energy you want to attract.', author: 'Ancient Proverb' },
      { text: 'Joy is not in things; it is in us.', author: 'Richard Wagner' },
      { text: 'Confidence is not "they will like me." Confidence is "I\'ll be fine if they don\'t."', author: 'Unknown' },
      { text: 'Love is composed of a single soul inhabiting two bodies.', author: 'Aristotle' },
    ],
    luteal: [
      { text: 'The greatest remedy for anger is delay.', author: 'Seneca' },
      { text: 'Speak when you are angry and you will make the best speech you will ever regret.', author: 'Ambrose Bierce' },
      { text: 'Silence is a true friend who never betrays.', author: 'Confucius' },
      { text: 'Be kind, for everyone you meet is fighting a battle you know nothing about.', author: 'Wendy Mass' },
      { text: 'Kindness is the language which the deaf can hear and the blind can see.', author: 'Mark Twain' },
      { text: 'When you talk, you are only repeating what you know. But if you listen, you may learn something new.', author: 'Dalai Lama' },
      { text: 'Anyone can become angry — that is easy. But to be angry with the right person, to the right degree, at the right time — that is not easy.', author: 'Aristotle' },
      { text: 'Patience is not the ability to wait, but the ability to keep a good attitude while waiting.', author: 'Joyce Meyer' },
      { text: 'He that can have patience can have what he will.', author: 'Benjamin Franklin' },
      { text: 'No act of kindness, no matter how small, is ever wasted.', author: 'Aesop' },
      { text: 'Better to remain silent and be thought a fool than to speak and remove all doubt.', author: 'Abraham Lincoln' },
      { text: 'In the confrontation between the stream and the rock, the stream always wins — not through strength but through persistence.', author: 'Buddha' },
      { text: 'A gentle answer turns away wrath, but a harsh word stirs up anger.', author: 'Proverbs 15:1' },
      { text: 'The first to apologize is the bravest. The first to forgive is the strongest.', author: 'Ancient Proverb' },
      { text: 'Grant me the serenity to accept what I cannot change, courage to change what I can, and wisdom to know the difference.', author: 'Serenity Prayer' },
    ],
  };

  function getDailyQuote(phase) {
    const quotes = QUOTES[phase];
    const today = new Date();
    const dayIndex = Math.floor(today.getTime() / (1000 * 60 * 60 * 24));
    return quotes[dayIndex % quotes.length];
  }

  // Moon SVG graphics — one per cycle phase
  function getMoonSVG(phase, size = 80) {
    const id = phase + size;
    const svgs = {
      menstrual: `<svg viewBox="0 0 80 80" width="${size}" height="${size}" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="nm-glow-${id}" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#f87171" stop-opacity="0.18"/>
            <stop offset="100%" stop-color="#f87171" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <circle cx="40" cy="40" r="38" fill="url(#nm-glow-${id})"/>
        <circle cx="40" cy="40" r="28" fill="#0c0c1e" stroke="#f87171" stroke-width="1.5" stroke-opacity="0.55"/>
      </svg>`,

      follicular: `<svg viewBox="0 0 80 80" width="${size}" height="${size}" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <mask id="wc-mask-${id}">
            <circle cx="40" cy="40" r="28" fill="white"/>
            <circle cx="20" cy="40" r="26" fill="black"/>
          </mask>
          <radialGradient id="wc-glow-${id}" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#fbbf24" stop-opacity="0.14"/>
            <stop offset="100%" stop-color="#fbbf24" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <circle cx="40" cy="40" r="38" fill="url(#wc-glow-${id})"/>
        <circle cx="40" cy="40" r="28" fill="#0c0c1e" stroke="#fbbf24" stroke-width="0.8" stroke-opacity="0.25"/>
        <circle cx="40" cy="40" r="28" fill="#fbbf24" mask="url(#wc-mask-${id})" opacity="0.88"/>
      </svg>`,

      ovulation: `<svg viewBox="0 0 80 80" width="${size}" height="${size}" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="fm-grad-${id}" cx="38%" cy="32%" r="68%">
            <stop offset="0%" stop-color="#ecfdf5"/>
            <stop offset="50%" stop-color="#34d399"/>
            <stop offset="100%" stop-color="#059669"/>
          </radialGradient>
          <radialGradient id="fm-glow-${id}" cx="50%" cy="50%" r="50%">
            <stop offset="30%" stop-color="#34d399" stop-opacity="0.22"/>
            <stop offset="100%" stop-color="#34d399" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <circle cx="40" cy="40" r="38" fill="url(#fm-glow-${id})"/>
        <circle cx="40" cy="40" r="28" fill="url(#fm-grad-${id})"/>
      </svg>`,

      luteal: `<svg viewBox="0 0 80 80" width="${size}" height="${size}" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <mask id="waning-mask-${id}">
            <circle cx="40" cy="40" r="28" fill="white"/>
            <circle cx="60" cy="40" r="26" fill="black"/>
          </mask>
          <radialGradient id="waning-glow-${id}" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#a78bfa" stop-opacity="0.14"/>
            <stop offset="100%" stop-color="#a78bfa" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <circle cx="40" cy="40" r="38" fill="url(#waning-glow-${id})"/>
        <circle cx="40" cy="40" r="28" fill="#0c0c1e" stroke="#a78bfa" stroke-width="0.8" stroke-opacity="0.25"/>
        <circle cx="40" cy="40" r="28" fill="#a78bfa" mask="url(#waning-mask-${id})" opacity="0.88"/>
      </svg>`
    };
    return svgs[phase] || svgs.menstrual;
  }

  // Phase data inlined for client-side use
  const PHASE_DATA = {
    menstrual: {
      name: 'Menstrual', emoji: '🌑', moonName: 'New Moon', color: '#f87171', colorBg: 'rgba(239,68,68,0.12)', days: 'Days 1–5',
      tagline: 'Rest & Restore',
      whatsHappening: 'Her body is shedding the uterine lining. Hormones are at their lowest. This is her most physically demanding phase.',
      sheMayFeel: ['Cramping and lower back pain','Fatigue and low energy','Bloating','Mood swings or low mood','Food cravings (sweet or salty)','Headaches'],
      doThis: ['Be extra patient — she\'s dealing with real physical discomfort','Offer comfort food or her favorite snacks','Keep things low-key — couch time > big plans','A heating pad or hot water bottle goes a long way','Check in with "how are you feeling?" and mean it','Handle more of the household load quietly'],
      avoidThis: ['Starting arguments or serious conversations','Pressuring her to go out or socialize','Saying "it\'s just your period"','Making her feel bad for canceling plans'],
      insight: 'This is her most vulnerable phase. Low-key quality time is worth more than anything expensive right now.',
      proTip: 'Track which days are worst for her specifically — most women have 1–2 peak pain days. Knowing Day 2 is her hardest lets you plan ahead.',
      intimacyNote: 'Desire is generally lower but varies widely. Follow her lead. Some women feel relief from intimacy during this phase — never assume, always ask.',
    },
    follicular: {
      name: 'Follicular', emoji: '🌒', moonName: 'Waxing Crescent', color: '#fbbf24', colorBg: 'rgba(251,191,36,0.12)', days: 'Days 6–13',
      tagline: 'Rising Energy',
      whatsHappening: 'Estrogen is climbing. Her body is preparing for ovulation. Energy, mood, and optimism all trend upward.',
      sheMayFeel: ['Increasing energy and motivation','More positive and upbeat','Creative and adventurous','Social and chatty','Open to new ideas and plans'],
      doThis: ['Plan dates — she\'s in the mood for new experiences','Bring up future plans, trips, goals — she\'s receptive','Suggest trying something new together','Have important conversations you\'ve been putting off','Encourage her projects and ideas'],
      avoidThis: ['Being boring or checked out — she wants engagement','Wasting the window by making no plans','Shutting down her ideas or enthusiasm'],
      insight: 'Best time to have serious talks — about money, the relationship, future plans. She\'s optimistic and solution-oriented right now.',
      proTip: 'Book something for late in this phase or around ovulation. She\'ll be at peak confidence and will enjoy it most.',
      intimacyNote: 'Interest is building. She\'s feeling more attractive and connected. Good time for flirting and building tension.',
    },
    ovulation: {
      name: 'Ovulation', emoji: '🌕', moonName: 'Full Moon', color: '#34d399', colorBg: 'rgba(52,211,153,0.12)', days: 'Days 14–16',
      tagline: 'Peak Power',
      whatsHappening: 'The egg is released. Estrogen and testosterone peak. She is at her most confident, social, and energetic — this window lasts only a few days.',
      sheMayFeel: ['Most attractive and confident','High energy and vitality','Highly social and magnetic','Clear-headed and decisive','Highest libido of the month'],
      doThis: ['Compliment her genuinely — she\'s radiating right now','Plan something special: a nice dinner, a fun outing','Be present and attentive — she notices everything','Be romantic and intentional','Make her feel seen'],
      avoidThis: ['Being absent, distracted, or on your phone','Missing this window with zero effort','Being critical or dismissive','Picking fights'],
      insight: 'This is a 3-day window. She looks and feels her best. She\'s also most attuned to your level of engagement. Show up.',
      proTip: 'Whatever effort you put in here pays double dividends. This is the phase where shared memories get made.',
      intimacyNote: 'Peak libido. She\'s confident and wants to feel desired. Be intentional and present — highest-return window of the month.',
    },
    luteal: {
      name: 'Luteal', emoji: '🌘', moonName: 'Waning Moon', color: '#a78bfa', colorBg: 'rgba(167,139,250,0.12)', days: 'Days 17–28',
      tagline: 'Tread Carefully',
      whatsHappening: 'Progesterone rises then drops sharply. PMS symptoms emerge in the second half (roughly Days 22–28). Longest and most variable phase.',
      sheMayFeel: ['Irritability or short fuse','Anxiety or heightened worry','Bloating and water retention','Food cravings — especially chocolate, carbs, salt','Fatigue and lower motivation','Emotional sensitivity — things feel bigger'],
      doThis: ['Be extra patient — emotions are real even if the trigger seems small','Stock her favorite comfort foods','Don\'t take moods personally — it\'s hormonal, not about you','Offer comfort and presence over solutions','Validate: "that sounds really frustrating"','Keep the environment calm and low-stress'],
      avoidThis: ['Saying "you\'re being emotional" or "calm down"','Starting arguments or bringing up grievances','Making major financial or relationship decisions','Being critical of her appearance','Disappearing emotionally'],
      insight: 'Days 17–21 are manageable. Days 22–28 are the PMS zone — heightened sensitivity, real discomfort, lower tolerance. Adjust accordingly.',
      proTip: 'If a fight starts in Days 24–28 about something small, it\'s almost certainly not about that thing. Offer to revisit in a few days.',
      intimacyNote: 'Desire drops noticeably in late luteal. Physical comfort — holding, warmth — matters more than sex. Don\'t push, offer instead.',
    },
  };

  function getPhaseForDay(day, cycleLength = 28) {
    const lutealLength = 14;
    const ovulationDay = cycleLength - lutealLength;
    const menstrualLength = 5;
    const ovulationStart = ovulationDay - 1;
    const ovulationEnd = ovulationDay + 1;
    if (day <= menstrualLength) return 'menstrual';
    if (day < ovulationStart) return 'follicular';
    if (day <= ovulationEnd) return 'ovulation';
    return 'luteal';
  }

  function getCycleDayForDate(lastPeriodDate, targetDate, cycleLength = 28) {
    const last = new Date(lastPeriodDate);
    const diffMs = targetDate.getTime() - last.getTime();
    const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
    if (diffDays < 0) return -1;
    return (diffDays % cycleLength) + 1;
  }

  function loadData() {
    const stored = localStorage.getItem('cyclewise_data');
    if (!stored) return null;
    return JSON.parse(stored);
  }

  function saveData(data) {
    localStorage.setItem('cyclewise_data', JSON.stringify(data));
  }

  function isPro() {
    return !!localStorage.getItem('cyclewise_pro');
  }

  function renderTodayCard(data) {
    const today = new Date();
    const cycleDay = getCycleDayForDate(data.lastPeriodDate, today, data.cycleLength);
    const phase = getPhaseForDay(cycleDay, data.cycleLength);
    const p = PHASE_DATA[phase];

    document.getElementById('today-cycle-day').textContent = `Day ${cycleDay}`;
    document.getElementById('today-phase-emoji').textContent = p.emoji;
    document.getElementById('today-phase-name').textContent = p.name;
    document.getElementById('today-tagline').textContent = p.moonName + ' · ' + p.tagline;

    // Update today section background
    const todaySection = document.querySelector('.today-section');
    todaySection.style.background = `radial-gradient(ellipse 80% 60% at 50% 0%, ${p.colorBg.replace('0.12','0.18')} 0%, transparent 70%)`;

    // Phase color on badge
    document.getElementById('today-cycle-day').style.background = p.colorBg;
    document.getElementById('today-cycle-day').style.color = p.color;
    document.getElementById('today-cycle-day').style.border = `1px solid ${p.color}33`;

    // Briefing
    const briefing = document.getElementById('today-briefing');
    const quote = getDailyQuote(phase);
    briefing.innerHTML = `
      <div class="briefing-block">
        <h3 class="heading-feel">She may be feeling</h3>
        <ul>${p.sheMayFeel.map(f => `<li>${f}</li>`).join('')}</ul>
      </div>
      <div class="briefing-block do-block">
        <h3 class="heading-do">Do this today</h3>
        <ul>${p.doThis.slice(0,4).map(f => `<li>${f}</li>`).join('')}</ul>
      </div>
      <div class="quote-card" style="border-color:${p.color}22;">
        <div class="quote-mark" style="color:${p.color};">&#8220;</div>
        <blockquote>${quote.text}</blockquote>
        <cite>— ${quote.author}</cite>
      </div>
    `;

    document.getElementById('today-detail').innerHTML = '';

    // Pro section
    const proSec = document.getElementById('pro-section');
    if (isPro()) {
      proSec.innerHTML = `
        <div class="pro-content">
          <div class="pro-block">
            <h3>🌟 Insider Tip</h3>
            <p>${p.proTip}</p>
          </div>
          <div class="pro-block">
            <h3>💑 Intimacy Note</h3>
            <p>${p.intimacyNote}</p>
          </div>
        </div>
      `;
    } else {
      proSec.innerHTML = `
        <div class="pro-teaser">
          <div class="pro-teaser-inner">
            <div class="pro-teaser-lock">🔒</div>
            <div>
              <strong>Pro: Insider Tip + Intimacy Guidance</strong>
              <p>Unlock deeper daily briefings, phase transition warnings, and intimacy notes.</p>
            </div>
            <a href="/pro" class="btn btn-primary" style="white-space:nowrap;font-size:13px;padding:10px 18px;">Unlock Pro</a>
          </div>
        </div>
      `;
    }
  }

  function renderCalendar(data, year, month) {
    const monthLabel = new Date(year, month, 1).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
    document.getElementById('cal-month-label').textContent = monthLabel;

    const grid = document.getElementById('calendar-grid');
    const today = new Date();
    today.setHours(0,0,0,0);

    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const startDow = firstDay.getDay(); // 0=Sun

    let html = '<div class="cal-dow">Sun</div><div class="cal-dow">Mon</div><div class="cal-dow">Tue</div><div class="cal-dow">Wed</div><div class="cal-dow">Thu</div><div class="cal-dow">Fri</div><div class="cal-dow">Sat</div>';

    // Empty cells before first day
    for (let i = 0; i < startDow; i++) {
      html += '<div class="cal-cell empty"></div>';
    }

    for (let d = 1; d <= lastDay.getDate(); d++) {
      const date = new Date(year, month, d);
      const cycleDay = getCycleDayForDate(data.lastPeriodDate, date, data.cycleLength);
      const phase = cycleDay > 0 ? getPhaseForDay(cycleDay, data.cycleLength) : null;
      const p = phase ? PHASE_DATA[phase] : null;
      const isToday = date.getTime() === today.getTime();
      const isPast = date < today;
      const phaseShort = { menstrual: 'Menstrual', follicular: 'Follicular', ovulation: 'Ovulation', luteal: 'Luteal' };

      html += `<div class="cal-cell ${phase || ''} ${isToday ? 'cal-today' : ''} ${isPast ? 'cal-past' : ''}"
        style="${p ? `background:${p.colorBg.replace('0.12','0.18')};border-color:${p.color}33;` : 'background:var(--surface2);border-color:var(--border);'}"
        title="${p ? `Day ${cycleDay} — ${p.name}` : ''}">
        <span class="cal-num" style="${isToday ? `color:white;` : p ? `color:${p.color};` : 'color:var(--text-dim);'}">${d}</span>
        ${p ? `<span class="cal-cycle-day" style="color:${p.color};opacity:0.7;">Day ${cycleDay}</span>` : ''}
        ${p ? `<span class="cal-phase-name" style="color:${p.color};">${phaseShort[phase]}</span>` : ''}
        ${isToday ? `<span class="cal-today-dot" style="background:${p ? p.color : 'white'};"></span>` : ''}
      </div>`;
    }

    grid.innerHTML = html;
  }

  function renderPhaseGuide(phase) {
    const p = PHASE_DATA[phase];
    const pro = isPro();
    const content = document.getElementById('phase-guide-content');
    content.innerHTML = `
      <div class="guide-card" style="border-color:${p.color}33;">
        <div class="guide-header">
          <span class="guide-emoji">${getMoonSVG(phase, 56)}</span>
          <div>
            <div class="guide-phase-label" style="color:${p.color};">${p.name} · ${p.days}</div>
            <h3>${p.tagline}</h3>
          </div>
        </div>
        <p class="guide-happening">${p.whatsHappening}</p>

        <div class="guide-grid">
          <div class="guide-block">
            <h4>She may feel</h4>
            <ul>${p.sheMayFeel.map(f => `<li>${f}</li>`).join('')}</ul>
          </div>
          <div class="guide-block do-guide">
            <h4>✅ Do this</h4>
            <ul>${p.doThis.map(f => `<li>${f}</li>`).join('')}</ul>
          </div>
          <div class="guide-block avoid-guide">
            <h4>❌ Avoid</h4>
            <ul>${p.avoidThis.map(f => `<li>${f}</li>`).join('')}</ul>
          </div>
        </div>

        <div class="guide-insight">💡 ${p.insight}</div>

        ${pro ? `
          <div class="guide-pro-content">
            <div class="guide-pro-block">
              <h4>🌟 Insider Tip</h4>
              <p>${p.proTip}</p>
            </div>
            <div class="guide-pro-block">
              <h4>💑 Intimacy Note</h4>
              <p>${p.intimacyNote}</p>
            </div>
          </div>
        ` : `
          <div class="guide-pro-lock">
            🔒 <a href="/pro">Unlock Pro</a> to see the Insider Tip and Intimacy Note for each phase.
          </div>
        `}
      </div>
    `;
  }

  // Init
  let calYear, calMonth;

  function init() {
    const data = loadData();

    if (!data) {
      document.getElementById('setup-modal').style.display = 'flex';
      document.getElementById('app-content').style.display = 'none';

      // Pre-fill today's date
      const today = new Date();
      const yyyy = today.getFullYear();
      const mm = String(today.getMonth() + 1).padStart(2, '0');
      const dd = String(today.getDate()).padStart(2, '0');
      document.getElementById('period-date').value = `${yyyy}-${mm}-${dd}`;
    } else {
      document.getElementById('setup-modal').style.display = 'none';
      document.getElementById('app-content').style.display = 'block';

      renderTodayCard(data);

      const now = new Date();
      calYear = now.getFullYear();
      calMonth = now.getMonth();
      renderCalendar(data, calYear, calMonth);
      renderPhaseGuide('menstrual');

      // Check if pro token in URL
      const urlParams = new URLSearchParams(window.location.search);
      const token = urlParams.get('pro');
      if (token) {
        localStorage.setItem('cyclewise_pro', token);
        window.history.replaceState({}, '', '/app');
        location.reload();
      }
    }
  }

  document.getElementById('setup-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const date = document.getElementById('period-date').value;
    const length = parseInt(document.getElementById('cycle-length').value) || 28;
    saveData({ lastPeriodDate: date, cycleLength: length });
    init();
  });

  document.getElementById('new-period-btn').addEventListener('click', () => {
    if (!confirm('Mark today as Day 1 of her new period?')) return;
    const data = loadData();
    const today = new Date();
    const yyyy = today.getFullYear();
    const mm = String(today.getMonth() + 1).padStart(2, '0');
    const dd = String(today.getDate()).padStart(2, '0');
    saveData({ ...data, lastPeriodDate: `${yyyy}-${mm}-${dd}` });
    renderTodayCard(loadData());
    renderCalendar(loadData(), calYear, calMonth);
    const btn = document.getElementById('new-period-btn');
    btn.textContent = 'Updated ✔';
    btn.style.background = 'rgba(52,211,153,0.15)';
    btn.style.borderColor = '#34d399';
    btn.style.color = '#34d399';
    setTimeout(() => {
      btn.textContent = 'New Period';
      btn.style.background = '';
      btn.style.borderColor = '';
      btn.style.color = '';
    }, 2000);
  });

  document.getElementById('edit-setup').addEventListener('click', () => {
    const data = loadData();
    if (data) {
      document.getElementById('period-date').value = data.lastPeriodDate;
      document.getElementById('cycle-length').value = data.cycleLength;
    }
    document.getElementById('setup-modal').style.display = 'flex';
  });

  document.getElementById('cal-prev').addEventListener('click', () => {
    calMonth--;
    if (calMonth < 0) { calMonth = 11; calYear--; }
    renderCalendar(loadData(), calYear, calMonth);
  });
  document.getElementById('cal-next').addEventListener('click', () => {
    calMonth++;
    if (calMonth > 11) { calMonth = 0; calYear++; }
    renderCalendar(loadData(), calYear, calMonth);
  });

  document.getElementById('phase-guide-tabs').addEventListener('click', (e) => {
    const btn = e.target.closest('.tab-btn');
    if (!btn) return;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderPhaseGuide(btn.dataset.phase);
  });

  document.getElementById('setup-modal').addEventListener('click', (e) => {
    if (e.target === document.getElementById('setup-modal') && loadData()) {
      document.getElementById('setup-modal').style.display = 'none';
    }
  });

  init();
</script>

