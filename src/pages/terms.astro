---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Terms of Service — CycleWise">
  <div class="page-wrap prose" style="max-width:680px;">
    <h1>Terms of Service</h1>
    <p><em>Last updated: June 14, 2026</em></p>
    <h2>Use of service</h2>
    <p>CycleWise is an educational tool for informational purposes only. It is not a medical device and should not be used for contraception or medical decisions.</p>
    <h2>Pro access</h2>
    <p>Pro access is a one-time purchase. Refunds are available within 7 days of purchase — contact <a href="mailto:hello@cyclewise.app">hello@cyclewise.app</a>.</p>
    <h2>Disclaimer</h2>
    <p>Cycle tracking is approximate. Individual cycles vary. CycleWise provides general guidance based on average cycle patterns and is not a substitute for medical advice.</p>
    <h2>Contact</h2>
    <p><a href="mailto:hello@cyclewise.app">hello@cyclewise.app</a></p>
  </div>
</Layout>

<style>
  .prose h1 { margin-bottom: 10px; }
  .prose em { color: var(--text-dim); font-size: 14px; display: block; margin-bottom: 32px; }
  .prose h2 { margin-top: 40px; margin-bottom: 12px; }
  .prose p { color: var(--text-muted); font-size: 15px; line-height: 1.75; margin-bottom: 14px; }
  .prose a { color: var(--pink); }
</style>
